{
    "name": "bugban/symfony",
    "description": "Bugban error & monitoring SDK — Symfony bundle that auto-captures exceptions.",
    "type": "symfony-bundle",
    "keywords": ["bugban", "symfony", "error-tracking", "monitoring", "exceptions"],
    "license": "MIT",
    "require": {
        "php": ">=7.1",
        "bugban/php-sdk": "^1.5.2",
        "symfony/http-kernel": ">=3.4",
        "symfony/dependency-injection": ">=3.4",
        "symfony/config": ">=3.4",
        "symfony/event-dispatcher": ">=3.4"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../php-sdk"
        }
    ],
    "autoload": {
        "psr-4": {
            "Bugban\\Symfony\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
